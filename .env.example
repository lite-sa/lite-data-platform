# Copy to .env at the repo root and fill in. .env is gitignored.
# Loaded by Settings.from_env() via python-dotenv; variables already
# exported in the shell always win. Full config map: docs/configuration.md
GCP_PROJECT=lite-data-dev
GCS_BUCKET=lite-data-dev-raw

# Source connection: set EXACTLY ONE of the two modes below
# (Settings.from_env() refuses both/neither). Neither mode names a
# database — ingestion is one pipeline per source database, and each
# pipeline file states its own (see app_etl/ingestion/).

# Mode 1 — Cloud SQL Auth Proxy on localhost (the laptop mode):
#   cloud-sql-proxy --auto-iam-authn --port=5432 lite-litecore-dev:me-central2:non-cde-postgres
# IAM user, no password; Settings.pg_dsn() url-encodes the '@' itself.
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=your.name@lite.sa

# Mode 2 — in-process Cloud SQL IAM auth (Python Connector). This is what
# Cloud Run jobs use; on a laptop prefer Mode 1 + the proxy.
# PG_INSTANCE_CONNECTION_NAME=lite-litecore-dev:me-central2:non-cde-postgres
# PG_IAM_USER=sa-app-etl@lite-data-dev.iam
# PG_IP_TYPE=public   # laptop only; Cloud Run keeps the default "private"

# Local runs must never land in the real raw dataset (default raw_litecore)
# — keep this override until dev-source ingestion is promoted deliberately.
# Staging files follow the same prefix (gs://$GCS_BUCKET/raw_test/).
BQ_DATASET_RAW=raw_test

# dbt's default/home dataset (default core): staging views + the
# canonical intermediate/marts layer (payments today). Same rule as
# BQ_DATASET_RAW: keep local runs out of the real dataset.
BQ_DATASET_CORE=core_test

# dbt marts dataset for the one demoted-but-surviving AML model
# (aml_merchant_features only), read by dbt AND by the alert exporter
# (app_etl/export/aml_alerts.py). Same rule as BQ_DATASET_RAW: keep local
# runs out of the real dataset.
BQ_DATASET_AML=aml_test

# Alert egress bucket (export job only; docs/aml-alert-design.md contract).
# Leave unset locally unless you are testing the exporter — and then point
# it at a scratch location, never the real egress bucket.
# GCS_BUCKET_EGRESS=lite-data-dev-egress
